# ── Exemplo de variáveis de ambiente (committed) ─────────────────────────────
# Copie para .env.local e preencha. .env.local NÃO é versionado.
# Em DEV, aponte o Supabase para o projeto de DEV (usefokio-crm-dev).
# NUNCA colocar chaves de PRODUÇÃO no .env.local.

# Supabase (obrigatório)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon key do projeto>"
SUPABASE_SERVICE_ROLE_KEY="<service_role do projeto — usado nas rotas /api>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Webmaster (em dev a verificação é bypassada)
WEBMASTER_EMAIL="usefokio@gmail.com"
NEXT_PUBLIC_WEBMASTER_ID="<uuid do usuário webmaster>"

# Cripto das chaves de gateway/SMTP no banco (64 hex = 32 bytes). Use um valor SÓ de dev.
ASAAS_ENC_SECRET="<64 caracteres hex>"

# Webhooks / cron
ASAAS_WEBHOOK_TOKEN="<token>"
CRON_SECRET="<token>"

# Email (Resend) — opcional em dev
RESEND_API_KEY="<re_...>"
EMAIL_FROM="UseFokio <noreply@usefokio.com.br>"

# Google Places (avaliações do Google no site/landing) — opcional; sem ela, usa fallback
# Criar no Google Cloud: ativar "Places API" + Billing; restringir a chave à Places API.
GOOGLE_PLACES_API_KEY="<AIza...>"

# Storage Cloudflare R2 — opcional em dev
R2_ACCOUNT_ID="<account id>"
R2_ACCESS_KEY_ID="<access key>"
R2_SECRET_ACCESS_KEY="<secret>"
R2_BUCKET_NAME="<bucket>"
NEXT_PUBLIC_R2_PUBLIC_URL="https://<dominio-publico-do-bucket>"
